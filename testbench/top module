/Top Module
module tb_top;
  alu_if vif();
  alu_4bit dut(
    .a(vif.a),
    .b(vif.b),
    .op(vif.op),
    .result(vif.result),
    .carry(vif.carry)
  );
  initial begin
    vif.clk = 0;
    forever #5 vif.clk = ~vif.clk;
  end
  initial begin
    uvm_config_db#(virtual alu_if)::set(null,"*","vif",vif);
    run_test("alu_test");
  end
  initial begin
    $dumpfile("wave.vcd");
    $dumpvars(0,tb_top);
  end    
endmodule
